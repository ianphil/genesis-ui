    "@typescript-eslint/parser": "^5.62.0",
    "@vitest/coverage-v8": "^4.1.4",
    "electron": "41.2.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.7.0",
    "vite": "^5.4.21",
    "vitest": "^4.1.4"
